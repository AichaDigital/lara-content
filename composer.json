{
    "name": "aichadigital/lara-content",
    "description": "Content management package for Laravel with pages, posts, blocks and menus. Blade + Livewire, multilingual support.",
    "keywords": [
        "aichadigital",
        "laravel",
        "content",
        "cms",
        "pages",
        "posts",
        "blocks",
        "menus",
        "livewire"
    ],
    "homepage": "https://github.com/AichaDigital/lara-content",
    "license": "AGPL-3.0-or-later",
    "authors": [
        {
            "name": "Abdelkarim Mateos Sanchez",
            "email": "abdelkarim.mateos@castris.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^12.0||^13.0",
        "spatie/laravel-package-tools": "^1.16",
        "spatie/laravel-translatable": "^6.13",
        "stevebauman/purify": "^6.2",
        "league/commonmark": "^2.5"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.13",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^10.0||^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "suggest": {
        "livewire/livewire": "Required for interactive blocks like ContactForm (^4.0)"
    },
    "autoload": {
        "psr-4": {
            "AichaDigital\\LaraContent\\": "src/",
            "AichaDigital\\LaraContent\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AichaDigital\\LaraContent\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "pint": "vendor/bin/pint",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=1G",
        "phpstan-baseline": "vendor/bin/phpstan analyse --generate-baseline --memory-limit=1G",
        "quality": [
            "@pint",
            "@phpstan",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AichaDigital\\LaraContent\\ContentServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
